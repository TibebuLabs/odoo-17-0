<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Alert Tree View -->
    <record id="view_custom_stock_alert_tree" model="ir.ui.view">
        <field name="name">custom.stock.alert.tree</field>
        <field name="model">custom.stock.alert</field>
        <field name="arch" type="xml">
            <tree string="Stock Alerts"
                decoration-danger="alert_type in ['out_of_stock','critical'] and state == 'open'"
                decoration-warning="alert_type == 'low_stock' and state == 'open'"
                decoration-muted="state in ['resolved','ignored']">
                <field name="reference"/>
                <field name="priority" widget="priority"/>
                <field name="product_tmpl_id"/>
                <field name="alert_type" widget="badge"
                    decoration-danger="alert_type in ['out_of_stock','critical']"
                    decoration-warning="alert_type == 'low_stock'"
                    decoration-info="alert_type == 'overstock'"/>
                <field name="current_qty"/>
                <field name="min_qty"/>
                <field name="warehouse_id"/>
                <field name="assigned_to"/>
                <field name="state" widget="badge"
                    decoration-danger="state == 'open'"
                    decoration-warning="state == 'in_progress'"
                    decoration-success="state == 'resolved'"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>

    <!-- Alert Form View -->
    <record id="view_custom_stock_alert_form" model="ir.ui.view">
        <field name="name">custom.stock.alert.form</field>
        <field name="model">custom.stock.alert</field>
        <field name="arch" type="xml">
            <form string="Stock Alert">
                <header>
                    <button name="action_in_progress" string="Start Working"
                        type="object" class="btn-primary"
                        invisible="state != 'open'"/>
                    <button name="action_resolve" string="Mark Resolved"
                        type="object" class="btn-success"
                        invisible="state not in ['open','in_progress']"/>
                    <button name="action_ignore" string="Ignore"
                        type="object"
                        invisible="state not in ['open','in_progress']"/>
                    <button name="action_reopen" string="Reopen"
                        type="object"
                        invisible="state not in ['resolved','ignored']"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="open,in_progress,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="priority" widget="priority" class="me-2"/>
                            <field name="reference" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Alert Details">
                            <field name="product_tmpl_id"/>
                            <field name="product_id"/>
                            <field name="alert_type"/>
                            <field name="warehouse_id"/>
                        </group>
                        <group string="Stock Info">
                            <field name="current_qty"/>
                            <field name="min_qty"/>
                            <field name="assigned_to"/>
                            <field name="resolved_date"/>
                        </group>
                    </group>
                    <group string="Resolution">
                        <field name="resolution_note" placeholder="Describe how this was resolved..."/>
                        <field name="notes" placeholder="Additional notes..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Alert Kanban View -->
    <record id="view_custom_stock_alert_kanban" model="ir.ui.view">
        <field name="name">custom.stock.alert.kanban</field>
        <field name="model">custom.stock.alert</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="reference"/>
                <field name="product_tmpl_id"/>
                <field name="alert_type"/>
                <field name="current_qty"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="assigned_to"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="product_tmpl_id"/>
                                    </strong>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="alert_type" widget="badge"/>
                                <br/>
                                Qty: <field name="current_qty"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="reference" class="text-muted"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="assigned_to" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Alert Search View -->
    <record id="view_custom_stock_alert_search" model="ir.ui.view">
        <field name="name">custom.stock.alert.search</field>
        <field name="model">custom.stock.alert</field>
        <field name="arch" type="xml">
            <search string="Search Alerts">
                <field name="reference"/>
                <field name="product_tmpl_id"/>
                <field name="assigned_to"/>
                <filter string="Open" name="filter_open" domain="[('state','=','open')]"/>
                <filter string="In Progress" name="filter_in_progress"
                    domain="[('state','=','in_progress')]"/>
                <filter string="Critical" name="filter_critical"
                    domain="[('alert_type','in',['critical','out_of_stock'])]"/>
                <filter string="My Alerts" name="filter_mine"
                    domain="[('assigned_to','=',uid)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Alert Type" name="group_type"
                        context="{'group_by': 'alert_type'}"/>
                    <filter string="Status" name="group_state"
                        context="{'group_by': 'state'}"/>
                    <filter string="Warehouse" name="group_warehouse"
                        context="{'group_by': 'warehouse_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Alert Action -->
    <record id="action_custom_stock_alert" model="ir.actions.act_window">
        <field name="name">Stock Alerts</field>
        <field name="res_model">custom.stock.alert</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{'search_default_filter_open': 1}</field>
    </record>
</odoo>
